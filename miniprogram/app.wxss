/**app.wxss**/

page {
  background-color: #f5f5f5;
  color: #333;
  font-family: PingFang SC, -apple-system, sans-serif;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}
