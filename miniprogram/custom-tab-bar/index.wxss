.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #eee;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.06);
  padding: 10rpx 0 env(safe-area-inset-bottom);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 0;
}

.tab-bar-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.tab-bar-text {
  font-size: 20rpx;
}
