<!-- 登录界面 -->
<view class="login-page">
  <!-- 装饰背景 -->
  <view class="bg-decor">
    <view class="circle circle-1"></view>
    <view class="circle circle-2"></view>
    <view class="circle circle-3"></view>
    <view class="dot-grid">
      <view class="dot-row" wx:for="{{6}}" wx:key="*this">
        <view class="dot" wx:for="{{6}}" wx:for-item="d" wx:key="*this"></view>
      </view>
    </view>
  </view>

  <!-- 品牌区 -->
  <view class="brand-area">
    <view class="logo-ring">
      <view class="logo-inner">
        <text class="logo-icon">📖</text>
      </view>
    </view>
    <text class="brand-name">智阅 · 深析</text>
    <text class="brand-desc">AI 驱动的学术论文精读助手</text>
  </view>

  <!-- 操作区 -->
  <view class="action-area">
    <view class="nickname-input-wrap">
      <input class="nickname-input" placeholder="输入你的昵称" value="{{nickname}}" bindinput="onNickInput" maxlength="20" />
    </view>
    <button class="enter-btn" bindtap="onEnter">
      <text class="enter-text">{{nickname ? '进入应用' : '跳过，直接进入'}}</text>
    </button>
    <text class="privacy-hint">可在「我的」页面随时修改昵称</text>
  </view>
</view>
