/**me.wxss**/

.page {
  min-height: 100vh;
  box-sizing: border-box;
}

/* 身份卡片 */
.identity-card {
  display: flex;
  align-items: center;
  margin: 30rpx;
  padding: 36rpx 28rpx;
  background-color: #2b2b4b;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-text {
  font-size: 50rpx;
}

.identity-info {
  flex: 1;
  margin-left: 24rpx;
}

.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.signature {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.edit-arrow {
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.4);
  padding-left: 16rpx;
}

/* 数据统计行 */
.stats-row {
  display: flex;
  align-items: center;
  margin: 0 30rpx 30rpx;
  padding: 32rpx 0;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #2b2b4b;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  height: 48rpx;
  background-color: #eee;
}

/* 功能分组 */
.menu-group {
  margin: 0 30rpx 24rpx;
}

.group-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 14rpx;
  padding-left: 4rpx;
}

.menu-card {
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx;
}

.menu-item + .menu-item {
  border-top: 1rpx solid #f5f5f5;
}

.menu-label {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 34rpx;
  color: #ccc;
}

/* 退出登录 */
.logout-item {
  justify-content: center;
}

.logout-label {
  font-size: 28rpx;
  color: #e54545;
}
