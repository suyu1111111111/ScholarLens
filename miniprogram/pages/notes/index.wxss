/**notes.wxss**/

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
}

/* 标签切换栏 */
.tab-bar {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 28rpx;
}

.tab-item {
  font-size: 28rpx;
  color: #999;
  padding-bottom: 8rpx;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #2b2b4b;
  font-weight: 600;
  border-bottom-color: #2b2b4b;
}

/* 搜索框 */
.search-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  margin: 0 30rpx 20rpx;
  padding: 0 24rpx;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
}

/* 笔记列表 */
.note-list {
  flex: 1;
  padding: 0 30rpx;
}

.note-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 20rpx;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.note-color-bar {
  width: 8rpx;
  flex-shrink: 0;
}

.note-body {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.note-excerpt {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.note-annotation {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.note-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx 24rpx 24rpx 0;
  flex-shrink: 0;
}

.note-date {
  font-size: 22rpx;
  color: #bbb;
  margin-bottom: 8rpx;
}

.note-source {
  font-size: 20rpx;
  color: #ccc;
}

/* 按论文分组 */
.note-group {
  margin-bottom: 32rpx;
}

.group-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.group-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.group-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.group-count {
  font-size: 22rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 24rpx;
  color: #bbb;
  margin-bottom: 48rpx;
}

.go-read-btn {
  width: 320rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #2b2b4b;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8px;
  border: none;
}

.go-read-btn::after {
  border: none;
}
