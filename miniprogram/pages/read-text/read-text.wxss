.page{display:flex;flex-direction:column;height:100vh;background:#f5f5f5}
.center-state{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:16px}
.loading-icon{font-size:48px}
.loading-text{color:#999;font-size:14px}
.error-icon{width:48px;height:48px;line-height:48px;text-align:center;background:#e54545;color:#fff;border-radius:50%;font-size:24px;font-weight:bold}
.error-text{color:#e54545;font-size:14px;max-width:80%;text-align:center}

/* 正文区 */
.reader-body{flex:1;display:flex;flex-direction:column;overflow:hidden}
.content-scroll{flex:1;padding:0 16px}
.paragraphs{padding-top:12px}
.para-block{position:relative;background:#fff;border-radius:8px;padding:14px 16px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.para-text{color:#222;display:block}
.para-badge{position:absolute;top:8px;right:8px;background:#1a73e8;color:#fff;font-size:11px;min-width:18px;height:18px;line-height:18px;border-radius:9px;text-align:center;padding:0 5px}
.para-annos{margin-top:10px;padding-top:8px;border-top:1px solid #eee}
.anno-tag{padding:6px 10px;margin-bottom:6px;background:#f0f4ff;border-left:3px solid #1a73e8;border-radius:0 4px 4px 0}
.anno-content{font-size:13px;color:#333;display:block}
.anno-time{font-size:11px;color:#999;margin-top:2px;display:block}
.bottom-pad{height:120px}

/* 底部工具栏 */
.toolbar{background:#fff;border-top:2px solid #1a73e8;padding:12px 16px;padding-bottom:calc(12px + env(safe-area-inset-bottom));margin-top:auto}
.page-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;padding:10px 12px;background:#f0f4ff;border-radius:8px}
.page-btn{font-size:15px;color:#1a73e8;padding:6px 12px;font-weight:bold}
.page-btn.disabled{color:#bbb}
.page-indicator{font-size:14px;color:#333;font-weight:bold}
.font-row{display:flex;align-items:center;gap:12px}
.font-label{font-size:13px;color:#666;white-space:nowrap}
.font-sizes{display:flex;gap:8px;flex-wrap:wrap}
.font-chip{padding:6px 14px;border-radius:16px;background:#eee;font-size:13px;color:#333}
.font-chip.active{background:#1a73e8;color:#fff}

/* 批注弹窗 */
.anno-mask{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:100}
.anno-modal{position:fixed;bottom:0;left:0;right:0;z-index:101;background:#fff;border-radius:16px 16px 0 0;padding:20px 16px;padding-bottom:calc(20px + env(safe-area-inset-bottom))}
.anno-modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.anno-modal-title{font-size:16px;font-weight:bold;color:#222}
.anno-modal-close{font-size:18px;color:#999;padding:4px}
.anno-ref{font-size:13px;color:#666;display:block;padding:10px;background:#f5f5f5;border-radius:6px;margin-bottom:12px;max-height:60px;overflow:hidden;line-height:1.4}
.anno-textarea{width:100%;height:80px;font-size:14px;border:1px solid #ddd;border-radius:8px;padding:10px;margin-bottom:12px}
.anno-save-btn{width:100%;background:#1a73e8;color:#fff;border:none;border-radius:8px;padding:12px;font-size:15px}

/* 全屏批注浮动工具栏 */
.fullscreen-toolbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 80;
  background: rgba(30, 30, 30, 0.92);
  padding: 10px 16px;
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
  backdrop-filter: blur(10px);
}
.fs-tool-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 8px;
}
.fs-tool-chip {
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  color: #ccc;
  font-size: 16px;
}
.fs-tool-chip.active {
  background: #1a73e8;
  color: #fff;
}
.fs-color-dot {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  border: 2px solid transparent;
}
.fs-color-dot.active {
  border-color: #fff;
  transform: scale(1.2);
}
.fs-exit-btn {
  font-size: 13px;
  color: #ff6b6b;
  margin-left: auto;
  padding: 6px 10px;
}
.fs-page-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20px;
  font-size: 14px;
  color: #fff;
}
.fs-page-nav .disabled {
  color: #555;
}
