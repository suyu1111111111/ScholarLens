<!--reader.wxml-->
<view class="container" style="background-color: {{bgColor}};">
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <view wx:else class="article">
    <view class="article-header">
      <view class="article-title">{{article.title}}</view>
      <view class="article-meta">
        <text class="article-author">{{article.author}}</text>
        <text class="article-date">{{article.date}}</text>
      </view>
    </view>

    <view class="article-content" style="font-size: {{fontSize}}px;">
      {{article.content}}
    </view>
  </view>

  <view class="toolbar">
    <view class="toolbar-item" bindtap="decreaseFont">
      <text class="toolbar-btn">A-</text>
    </view>
    <view class="toolbar-item" bindtap="increaseFont">
      <text class="toolbar-btn">A+</text>
    </view>
    <view class="toolbar-item color-picker">
      <view class="color-btn {{bgColor === '#f5f1e8' ? 'active' : ''}}" data-color="#f5f1e8" bindtap="changeBgColor" style="background-color:#f5f1e8;"></view>
      <view class="color-btn {{bgColor === '#e8f0e8' ? 'active' : ''}}" data-color="#e8f0e8" bindtap="changeBgColor" style="background-color:#e8f0e8;"></view>
      <view class="color-btn {{bgColor === '#2e2e2e' ? 'active' : ''}}" data-color="#2e2e2e" bindtap="changeBgColor" style="background-color:#2e2e2e;"></view>
    </view>
  </view>
</view>
