.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 上传中 */
.uploading-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.uploading-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.uploading-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.uploading-filename {
  font-size: 24rpx;
  color: #bbb;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.book-icon {
  font-size: 140rpx;
  margin-bottom: 40rpx;
}

.hint {
  font-size: 28rpx;
  color: #999;
  letter-spacing: 2rpx;
  margin-bottom: 60rpx;
}

.select-btn {
  width: 360rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #fff;
  color: #666;
  font-size: 28rpx;
  border-radius: 8px;
  border: 2rpx solid #ccc;
}

.select-btn::after {
  border: none;
}
